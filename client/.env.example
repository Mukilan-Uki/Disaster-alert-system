# ── Branding (src/config/appConfig.js reads these — change brand here, not in code) ──
REACT_APP_NAME=AlertLanka
REACT_APP_SHORT_NAME=AlertLanka
REACT_APP_TAGLINE=Early warning, built for Sri Lanka.
REACT_APP_DESCRIPTION=Real-time disaster alerts and weather intelligence for every district in Sri Lanka.
REACT_APP_COMPANY_NAME=AlertLanka
REACT_APP_SUPPORT_EMAIL=support@alertlanka.lk
REACT_APP_CONTACT_EMAIL=hello@alertlanka.lk
REACT_APP_PRIMARY_COLOR=#3FC1C9
REACT_APP_SECONDARY_COLOR=#F2A93B
REACT_APP_LOGO_URL=/logo.svg
REACT_APP_FAVICON_URL=/favicon.ico
REACT_APP_OG_IMAGE_URL=/og-image.png
REACT_APP_SITE_URL=https://alertlanka.lk
REACT_APP_SOCIAL_TWITTER=
REACT_APP_SOCIAL_FACEBOOK=

# ── Weather / map (existing) ──
REACT_APP_WEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
REACT_APP_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
REACT_APP_EMERGENCY_CONTACT=1990
REACT_APP_DEFAULT_CITY=Colombo
