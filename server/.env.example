OPENWEATHER_API_KEY=your_openweather_api_key_here
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/disaster_alert?retryWrites=true&w=majority
JWT_SECRET=your_long_random_jwt_secret_here
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@alertlanka.lk
WEATHER_CRON=*/15 * * * *
ENABLE_WEATHER_CRON=true
ADMIN_EMAILS=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=AlertLanka <alerts@alertlanka.lk>
PORT=5000
DEFAULT_CITY=Colombo
