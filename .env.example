# Copy to client/.env — frontend variables (prefix with REACT_APP_)
REACT_APP_WEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
REACT_APP_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
REACT_APP_EMERGENCY_CONTACT=1990
REACT_APP_DEFAULT_CITY=Colombo

# Backend variables belong in server/.env — see server/.env.example
# OPENWEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/disaster_alert?retryWrites=true&w=majority
# PORT=5000
# DEFAULT_CITY=Colombo
